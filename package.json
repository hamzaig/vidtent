{
  "name": "video-merge-tool",
  "version": "1.0.0",
  "description": "Foundation for an AI-assisted video generation workflow with clip editing, and planned AI script, TTS, and narration alignment.",
  "type": "module",
  "bin": {
    "video-tool": "./src/cli.js"
  },
  "scripts": {
    "build": "vite build --config ./web/vite.config.js",
    "cli": "node ./src/cli.js",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node ./src/server.js",
    "dev:web": "vite --config ./web/vite.config.js",
    "init": "node ./src/cli.js init",
    "run": "node ./src/cli.js run ./examples/job.sample.json",
    "compress": "node ./src/cli.js compress",
    "start": "node ./src/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "vite": "^7.1.11"
  }
}
